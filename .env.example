# Supabase Postgres (Settings → Database → Connection string)
# Prefer the transaction pooler URI for Vercel/serverless.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true"

# Dashboard password + cookie signing secret
DASHBOARD_PASSWORD="use-a-strong-password"
AUTH_SECRET="generate-a-long-random-string"

# TrendSpider webhook shared secret (?token=...)
WEBHOOK_TOKEN="generate-a-long-random-string"

# Webhook buy/sell orders are priced off a live Tiger quote, nudged by this
# percent (above quote for buys, below for sells) to improve limit-order fill
# odds. Optional; defaults to 0.15 in code. Order size itself is currently a
# hardcoded $100 notional in lib/execute-signal.ts (placeholder pending an AI
# portfolio-management skill).
WEBHOOK_LIMIT_BUFFER_PCT="0.15"

# Tiger OpenAPI (paper account recommended)
# Either TIGEROPEN_* names or the lowercase aliases used by the Python helpers work.
TIGEROPEN_TIGER_ID=""
TIGEROPEN_ACCOUNT=""
TIGEROPEN_LICENSE=""
TIGEROPEN_PRIVATE_KEY=""
# tiger_id=
# account=
# license=
# private_key_pk1=

# Set true only when intentionally trading a non-PAPER account
TIGER_ALLOW_LIVE=false

# --- Scheduled natural-language trade prompts ---

# Anthropic (schedule-time classification + run-time trading agent)
ANTHROPIC_API_KEY=""
# Optional override; defaults to a current Claude Sonnet model in code.
TRADE_AGENT_MODEL=""

# Upstash QStash (fires the execute webhook at the scheduled time)
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
# Publicly reachable base URL for this deployment (QStash calls back into it).
PUBLIC_BASE_URL="https://<your-domain>"

# Twilio WhatsApp (execution success/failure notification)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# WhatsApp-enabled Twilio sender, e.g. "whatsapp:+14155238886" (sandbox) or your approved number.
TWILIO_WHATSAPP_FROM=""
# Your WhatsApp number, e.g. "whatsapp:+61...". Must have opted in / joined the sandbox.
TWILIO_WHATSAPP_TO=""

# Hard guardrails enforced in code around the trade agent (independent of what it requests)
MAX_ORDER_SPEND_USD="2000"
MAX_CONTRACTS="10"
MAX_SHARES="500"
