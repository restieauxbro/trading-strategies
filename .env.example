# Supabase Postgres (Settings → Database → Connection string)
# Prefer the transaction pooler URI for Vercel/serverless.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true"

# Dashboard password + cookie signing secret
DASHBOARD_PASSWORD="use-a-strong-password"
AUTH_SECRET="generate-a-long-random-string"

# TrendSpider webhook shared secret (?token=...)
WEBHOOK_TOKEN="generate-a-long-random-string"

# Webhook buy/sell orders are priced off a live Tiger quote, nudged by this
# percent (above quote for buys, below for sells) to improve limit-order fill
# odds. Optional; defaults to 0.15 in code.
WEBHOOK_LIMIT_BUFFER_PCT="0.15"

# When QSTASH_TOKEN + PUBLIC_BASE_URL are set (see "Upstash QStash" below),
# incoming webhook signals are queued and drained one-at-a-time (never
# concurrently — see lib/qstash.ts) at up to this many signals per minute,
# so a burst of many simultaneous signals (e.g. a whole watchlist rotating
# at market close) can't blow through Tiger's own account-level API rate
# limits or race on the shared account snapshot the portfolio manager reads.
# Without QStash configured, signals execute immediately/concurrently as
# before (fine for light manual testing, not for real bursts).
# Optional; defaults to 20.
WEBHOOK_QUEUE_RATE_PER_MINUTE="20"

# --- Portfolio management (webhook `buy` sizing + trim-to-fund) ---
# See docs/feature-webhooks.md "Portfolio management" and lib/portfolio.ts.

# How many concurrent positions even-split sizing targets. Each new buy
# targets (total account equity / this number). Optional; defaults to 10.
PORTFOLIO_TARGET_POSITIONS="30"

# Max % of TOTAL EQUITY (not of the position itself) trimmable from any one
# existing position to help fund a new buy — a fixed dollar cap applied the
# same regardless of that position's own size. Optional; defaults to
# 50 / PORTFOLIO_TARGET_POSITIONS (half a default-sized position's worth)
# unless set explicitly here.
PORTFOLIO_MAX_TRIM_PCT_OF_EQUITY=""

# Skip trimming a position for less than this many dollars rather than
# generate a dust order. Optional; defaults to 20.
PORTFOLIO_MIN_TRIM_USD="20"

# Safety cap on how many different positions a single incoming buy signal is
# allowed to trim. Optional; defaults to 5.
PORTFOLIO_MAX_POSITIONS_TO_TRIM="10"

# Target % of total equity kept invested, surfaced on the dashboard and in
# each buy event's audit trail. Reporting only — there is no separate
# scheduled job that trims/tops up purely because this drifted with no new
# webhook signal. Optional; defaults to 80.
PORTFOLIO_MIN_INVESTED_PCT="80"

# Tiger OpenAPI (paper account recommended)
# Either TIGEROPEN_* names or the lowercase aliases used by the Python helpers work.
TIGEROPEN_TIGER_ID=""
TIGEROPEN_ACCOUNT=""
TIGEROPEN_LICENSE=""
TIGEROPEN_PRIVATE_KEY=""
# tiger_id=
# account=
# license=
# private_key_pk1=

# Set true only when intentionally trading a non-PAPER account
TIGER_ALLOW_LIVE=false

# --- Scheduled natural-language trade prompts ---

# Anthropic (schedule-time classification + run-time trading agent)
ANTHROPIC_API_KEY=""
# Optional override; defaults to a current Claude Sonnet model in code.
TRADE_AGENT_MODEL=""

# Upstash QStash — fires the trade-prompt execute webhook at the scheduled
# time, AND (see WEBHOOK_QUEUE_RATE_PER_MINUTE above) queues/throttles the
# TrendSpider webhook's own execution. Required for both features; without
# it the TrendSpider webhook falls back to immediate/concurrent execution.
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
# Publicly reachable base URL for this deployment (QStash calls back into it).
PUBLIC_BASE_URL="https://<your-domain>"

# Twilio WhatsApp (execution success/failure notification)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# WhatsApp-enabled Twilio sender, e.g. "whatsapp:+14155238886" (sandbox) or your approved number.
TWILIO_WHATSAPP_FROM=""
# Your WhatsApp number, e.g. "whatsapp:+61...". Must have opted in / joined the sandbox.
TWILIO_WHATSAPP_TO=""

# Hard guardrails enforced in code around the trade agent (independent of what it requests)
MAX_ORDER_SPEND_USD="2000"
MAX_CONTRACTS="10"
MAX_SHARES="500"
