//@version=6

// =============================================================================
// B-Xtrender Histogram Strategy (webhook) — multi-timeframe confirmation
// -----------------------------------------------------------------------------
// Ports the "Positive BX entry" TrendSpider bot's entry/exit logic onto the
// daily B-Xtrender histogram (see B-Xtrender.pine), using monthly + weekly
// B-Xtrender readings (pulled via request.security) as confirmation filters
// so entries/exits fire far less often than a plain daily zero-cross:
//
//   ENTER long when ALL of:
//     - Monthly histogram > monthlyFloor        (backdrop not deeply bearish)
//     - Weekly  histogram > weeklyEntryMin       (higher-TF momentum positive)
//     - Daily   histogram increased vs prior bar (rising / timing)
//     - Daily   histogram > 0
//
//   EXIT long when ALL of:
//     - Weekly histogram < weeklyExitMax         (higher-TF momentum fading)
//     - Daily   histogram < 0                    (momentum has actually flipped)
//
//   (Deliberately tighter than TrendSpider's original "OR daily decreased"
//   exit leg — that fired on any single down-tick even while daily was still
//   positive, which combined with a fast weekly dip caused a close-then-
//   immediate-reopen whipsaw right before a real move. Requiring daily to
//   have actually turned negative cuts that down at the cost of giving back
//   a bit more profit before exiting a fading-but-still-positive move.)
//
// Fires webhook alerts compatible with this repo's generic signal endpoint —
// see docs/webhooks.md for the full JSON schema and portfolio-sizing/
// execution behaviour on the receiving end.
//
// One-time setup in TradingView:
//   1. Add this script to a chart (Pine Editor → paste → "Add to chart"),
//      on the DAILY timeframe (weekly/monthly are pulled internally).
//   2. Right-click the chart → Add alert. Condition = this script, "Any
//      alert() function call". (There's no separate frequency dropdown for
//      this alert type — frequency is controlled entirely by the
//      alert.freq_* argument baked into each alert() call below.)
//   3. Under Notifications, enable "Webhook URL" and paste:
//        https://<your-domain>/api/webhooks/signal?token=<WEBHOOK_TOKEN>
//      (Webhook alerts require a paid TradingView plan — Essential or above.)
//   4. Leave the alert's Message box untouched — each alert() call below
//      supplies its own JSON body.
//
// Early alert (optional, see "Early alert" inputs below): fires once, N
// minutes before the daily close, instead of waiting for the confirmed
// close — trades a small amount of noise (the read an hour out can still
// differ from the actual close) for being able to execute same-day instead
// of at next day's open. Only meaningful in real-time forward testing —
// `timenow` doesn't replay historical wall-clock time, so this has no effect
// in the Strategy Tester's historical backtest. Safe to leave BOTH the early
// and close-confirmed alerts active: the receiving webhook already no-ops
// (`SKIPPED`) a same-day duplicate buy/sell for a symbol you already
// hold/don't hold, so the close-confirmed one just acts as a same-day
// fallback if the early one didn't fire.
// =============================================================================

strategy(
     "B-Xtrender Histogram Strategy (MTF)",
     overlay             = false,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,
     calc_on_every_tick  = false)

short_l1 = input.int(5,  "Short - L1", group = "B-Xtrender")
short_l2 = input.int(20, "Short - L2", group = "B-Xtrender")
short_l3 = input.int(5,  "Short - L3", group = "B-Xtrender")

monthlyFloor   = input.float(-10, "Monthly histogram must be greater than", group = "Confirmation filters")
weeklyEntryMin = input.float(0,   "Weekly histogram must be greater than (entry)", group = "Confirmation filters")
weeklyExitMax  = input.float(5,   "Weekly histogram must be less than (exit)", group = "Confirmation filters")
showMtfLines   = input.bool(true, "Plot weekly/monthly reference lines", group = "Display")

useEarlyAlert      = input.bool(false, "Fire an early alert N minutes before close (same-day entry/exit) instead of waiting for bar close", group = "Early alert")
minutesBeforeClose = input.int(60, "Minutes before close", minval = 1, group = "Early alert")

botName = input.string("bxtrender-histogram-mtf", "bot_name sent in webhook payload", group = "Webhook")

showDiagTable = input.bool(true,  "Show condition table (current bar)", group = "Diagnostics")
showDiagStrip = input.bool(false, "Show historical condition strip (rescales pane \u2014 turn on only while debugging)", group = "Diagnostics")

bxHistogram(l1, l2, l3) =>
    ta.rsi(ta.ema(close, l1) - ta.ema(close, l2), l3) - 50

shortTermXtrender = bxHistogram(short_l1, short_l2, short_l3)
weeklyXtrender    = request.security(syminfo.tickerid, "W", bxHistogram(short_l1, short_l2, short_l3), lookahead = barmerge.lookahead_off)
monthlyXtrender   = request.security(syminfo.tickerid, "M", bxHistogram(short_l1, short_l2, short_l3), lookahead = barmerge.lookahead_off)

shortXtrenderCol = shortTermXtrender > 0 ?
     (shortTermXtrender > shortTermXtrender[1] ? color.lime : #228B22) :
     (shortTermXtrender > shortTermXtrender[1] ? color.red : #8B0000)
plot(shortTermXtrender, color = shortXtrenderCol, style = plot.style_columns, linewidth = 1, title = "Daily B-Xtrender Histogram")
plot(showMtfLines ? weeklyXtrender  : na, color = color.new(color.aqua,   0), style = plot.style_line, linewidth = 2, title = "Weekly B-Xtrender Histogram")
plot(showMtfLines ? monthlyXtrender : na, color = color.new(color.yellow, 0), style = plot.style_line, linewidth = 2, title = "Monthly B-Xtrender Histogram")
hline(0, "Zero", color = color.gray)

dailyRising    = shortTermXtrender > shortTermXtrender[1]
dailyPositive  = shortTermXtrender > 0
dailyNegative  = shortTermXtrender < 0
monthlyOk      = monthlyXtrender > monthlyFloor
weeklyOkEntry  = weeklyXtrender > weeklyEntryMin
weeklyWeak     = weeklyXtrender < weeklyExitMax

// -----------------------------------------------------------------------------
// Diagnostic strip — one fixed-height row per entry/exit leg, colored green
// (true) / red (false) on every bar, so you can scroll back to any historical
// date (e.g. "why didn't it enter after earnings?") and read off exactly
// which leg(s) were blocking, instead of eyeballing line colors. OFF by
// default because plotting these fixed low values forces the pane's
// auto-scale to stretch down to fit them, visually squashing the histogram —
// only turn it on while actively debugging a specific stretch of history.
// -----------------------------------------------------------------------------
diagRowHeight = -8
diagRow(n) => -60 + n * diagRowHeight

plotchar(showDiagStrip ? diagRow(0) : na, "Diag: Monthly > floor",        "●", location.absolute, color = monthlyOk     ? color.lime : color.red, size = size.tiny)
plotchar(showDiagStrip ? diagRow(1) : na, "Diag: Weekly > entryMin",      "●", location.absolute, color = weeklyOkEntry ? color.lime : color.red, size = size.tiny)
plotchar(showDiagStrip ? diagRow(2) : na, "Diag: Daily rising",           "●", location.absolute, color = dailyRising   ? color.lime : color.red, size = size.tiny)
plotchar(showDiagStrip ? diagRow(3) : na, "Diag: Daily > 0",              "●", location.absolute, color = dailyPositive ? color.lime : color.red, size = size.tiny)
plotchar(showDiagStrip ? diagRow(4) : na, "Diag: Weekly < exitMax",       "●", location.absolute, color = weeklyWeak    ? color.orange : color.gray, size = size.tiny)
plotchar(showDiagStrip ? diagRow(5) : na, "Diag: Daily < 0 (exit)",       "●", location.absolute, color = dailyNegative ? color.orange : color.gray, size = size.tiny)

entryCondition = monthlyOk and weeklyOkEntry and dailyRising and dailyPositive
// Requires daily to have actually flipped negative (not just ticked down
// while still positive) — see header comment for why.
exitCondition  = weeklyWeak and dailyNegative

// Fire only on the bar the compound condition first becomes true, rather than
// every bar it happens to hold — this is what actually cuts signal frequency
// versus a plain crossover (whose single-value crossover already only fires
// once per cross, but the AND-of-four/two compound conditions above don't
// have that property automatically).
longCondition = entryCondition and not entryCondition[1]
closeCondition = exitCondition and not exitCondition[1]

// True for the whole final `minutesBeforeClose` window of the session, on the
// real-time bar only (see note above re: `timenow` and backtesting).
inEarlyWindow = (time_close - timenow) <= minutesBeforeClose * 60 * 1000 and (time_close - timenow) > 0

// -----------------------------------------------------------------------------
// Diagnostic table — full breakdown of the CURRENT (rightmost) bar only,
// answers "why isn't it entering/exiting right now". For historical bars,
// use the diagStrip above instead (tables don't track the crosshair/scrub
// position in Pine, only the last bar).
// -----------------------------------------------------------------------------
boolCell(cond) => cond ? "TRUE" : "false"
boolBg(cond) => cond ? color.new(color.lime, 40) : color.new(color.red, 40)

var table diagTable = table.new(position.top_right, 2, 11, border_width = 1, border_color = color.gray)

if showDiagTable and barstate.islast
    table.cell(diagTable, 0, 0, "Condition",                text_color = color.white, bgcolor = color.new(color.gray, 20), text_size = size.small)
    table.cell(diagTable, 1, 0, "State",                     text_color = color.white, bgcolor = color.new(color.gray, 20), text_size = size.small)

    table.cell(diagTable, 0, 1, "Daily hist",                text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 1, str.tostring(shortTermXtrender, "#.##"), text_color = color.white, text_size = size.small)
    table.cell(diagTable, 0, 2, "Weekly hist",                text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 2, str.tostring(weeklyXtrender, "#.##"),    text_color = color.white, text_size = size.small)
    table.cell(diagTable, 0, 3, "Monthly hist",               text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 3, str.tostring(monthlyXtrender, "#.##"),   text_color = color.white, text_size = size.small)

    table.cell(diagTable, 0, 4, "Monthly > floor",            text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 4, boolCell(monthlyOk),          text_color = color.white, bgcolor = boolBg(monthlyOk), text_size = size.small)
    table.cell(diagTable, 0, 5, "Weekly > entryMin",          text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 5, boolCell(weeklyOkEntry),      text_color = color.white, bgcolor = boolBg(weeklyOkEntry), text_size = size.small)
    table.cell(diagTable, 0, 6, "Daily rising",               text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 6, boolCell(dailyRising),        text_color = color.white, bgcolor = boolBg(dailyRising), text_size = size.small)
    table.cell(diagTable, 0, 7, "Daily > 0",                  text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 7, boolCell(dailyPositive),      text_color = color.white, bgcolor = boolBg(dailyPositive), text_size = size.small)
    table.cell(diagTable, 0, 8, "ENTRY fires here",           text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 8, boolCell(longCondition),      text_color = color.white, bgcolor = boolBg(longCondition), text_size = size.small)

    table.cell(diagTable, 0, 9, "Weekly < exitMax / Daily < 0", text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 9, boolCell(exitCondition),      text_color = color.white, bgcolor = boolBg(exitCondition), text_size = size.small)
    table.cell(diagTable, 0, 10, "EXIT fires here",           text_color = color.white, text_size = size.small)
    table.cell(diagTable, 1, 10, boolCell(closeCondition),    text_color = color.white, bgcolor = boolBg(closeCondition), text_size = size.small)

// Backtest fills always simulate at the confirmed daily close, regardless of
// the early-alert toggle, so Strategy Tester results stay comparable across
// runs — the toggle only changes when the *live webhook alert* fires below.
if longCondition
    strategy.entry("Long", strategy.long)

if closeCondition
    strategy.close("Long")

// -----------------------------------------------------------------------------
// Webhook payload — field names match lib/webhook-schema.ts on the receiving
// app. Only `symbol` + `action` are required there; `source`/`bot_name`/
// `timeframe`/`comment` are optional metadata carried through to the
// dashboard's webhook-events log. Quantity/price are always resolved
// server-side (see docs/webhooks.md), so none is sent here.
// -----------------------------------------------------------------------------
buildPayload(action, comment) =>
    '{"symbol":"'   + syminfo.ticker    +
     '","action":"' + action            +
     '","source":"tradingview"'         +
     ',"bot_name":"' + botName          +
     '","timeframe":"' + timeframe.period +
     '","comment":"' + comment + '"}'

// Early path: fires once per day (alert.freq_once_per_bar — the bar_index
// doesn't change again until tomorrow's daily bar opens) the first time the
// condition is true inside the last `minutesBeforeClose` minutes.
if useEarlyAlert and longCondition and inEarlyWindow
    alert(buildPayload("buy", "bxtrender-mtf-entry-confirmed-early"), alert.freq_once_per_bar)

if useEarlyAlert and closeCondition and inEarlyWindow
    alert(buildPayload("sell", "bxtrender-mtf-exit-confirmed-early"), alert.freq_once_per_bar)

// Close-confirmed path: the original behaviour, only using the fully
// confirmed bar close. Left ACTIVE even when useEarlyAlert is on, as a
// same-day fallback — see the note above re: duplicate signals being a
// harmless no-op server-side.
if longCondition
    alert(buildPayload("buy", "bxtrender-mtf-entry-confirmed"), alert.freq_once_per_bar_close)

if closeCondition
    alert(buildPayload("sell", "bxtrender-mtf-exit-confirmed"), alert.freq_once_per_bar_close)
